namespace rerun.testing.datatypes;

/// A test of the enum type.
enum EnumTest: ubyte {
    /// Invalid value. Won't show up in generated types.
    Invalid = 0,

    /// Great film.
    Up,

    /// Feeling blue.
    Down,

    /// Correct.
    Right (default),

    /// It's what's remaining.
    Left,

    /// It's the only way to go.
    Forward,

    /// Baby's got it.
    Back,
}

/// A test of an enumerate with specified values.
enum ValuedEnum: ubyte {
    /// Invalid value. Won't show up in generated types.
    Invalid = 0,

    /// One.
    One = 1,

    /// Two.
    Two = 2,

    /// Three.
    Three = 3,

    /// The answer to life, the universe, and everything.
    TheAnswer = 42,
}

/// Test datatype for fixed-size enum arrays.
struct FixedSizeEnumArray (
  "attr.arrow.transparent",
  "attr.rust.derive": "Copy, PartialEq, Eq",
  "attr.rust.repr": "transparent",
  "attr.rust.tuple_struct"
) {
  /// Fixed-size enum array.
  values: [rerun.testing.datatypes.EnumTest: 3] (order: 100);
}

/// A test enum with values that require more than one byte.
enum WideEnum: uint {
    /// Invalid value. Won't show up in generated types.
    Invalid = 0,

    /// Low value.
    Low = 1,

    /// High value.
    High = 65536,
}

/// Test datatype for fixed-size arrays of wide enums.
struct FixedSizeWideEnumArray (
  "attr.arrow.transparent",
  "attr.rust.derive": "Copy, PartialEq, Eq",
  "attr.rust.repr": "transparent",
  "attr.rust.tuple_struct"
) {
  /// Fixed-size wide enum array.
  values: [rerun.testing.datatypes.WideEnum: 2] (order: 100);
}

table MultiEnum (
    "attr.rust.derive": "Default, PartialEq, Eq"
) {
    /// The first value.
    value1: EnumTest (order: 100);

    /// The second value.
    value2: ValuedEnum (order: 200, nullable);
}
