
namespace rerun.components;

// ---

/// Defines how points are shaded.
enum PointShading: ubyte (
  "attr.docs.unreleased"
) {
  /// Invalid value. Won't show up in generated types.
  Invalid = 0,

  /// Radial gradient for a spherical shadow effect.
  Gradient (default),

  /// Flat shading.
  Flat,
}
